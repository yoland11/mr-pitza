# ===== Supabase =====
# انسخ هذا الملف إلى .env.local واملأ القيم من لوحة Supabase
# Copy to .env.local and fill from your Supabase project settings.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# مفتاح الخدمة — للاستخدام داخل API Routes فقط (لا تكشفه أبداً للمتصفح)
# Service role key — server-side only. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# ===== الموقع =====
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ===== واتساب المطعم (رقم دولي بدون +) =====
NEXT_PUBLIC_WHATSAPP_NUMBER=9647700000000

# ===== المرحلة 5: التكاملات (اختيارية — تُفعّل بإضافة المفاتيح) =====
# واتساب Business Cloud API (Meta) — لإرسال إشعارات الطلب والرد التلقائي
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_API_VERSION=v21.0
WHATSAPP_VERIFY_TOKEN=mr-pizza-verify

# Web Push (VAPID) — أنشئ المفاتيح عبر: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@mrpizza.app

# سرّ توقيع جلسة السائق (اختياري — يستخدم مفتاح الخدمة افتراضياً)
DRIVER_SESSION_SECRET=
